#!/usr/bin/env bash
set -e

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")

if [[ "$BRANCH" == "main" ]]; then
  TERRAFORM_STAGED=$(git diff --cached --name-only | grep '^terraform/' || true)
  if [[ -n "$TERRAFORM_STAGED" ]]; then
    echo ""
    echo "ERROR: main에 직접 terraform 변경을 커밋할 수 없습니다."
    echo "       브랜치를 만들고 PR로 머지하세요."
    echo ""
    echo "  git checkout -b feat/your-change"
    echo ""
    exit 1
  fi
fi
